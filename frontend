// --- BOOKING FORM COMPONENT ---
function BookingForm() {
  const [formData, setFormData] = useState({ name: '', contact: '', bhk: '', type: '' });
  const [loading, setLoading] = useState(false);
  const [toast, setToast] = useState(null); // 'success' | 'error' | null
  const [errors, setErrors] = useState({});

  const validate = () => {
    let tempErrors = {};
    if (!formData.name.trim()) tempErrors.name = "Name is required";
    if (!/^\d{10}$/.test(formData.contact)) tempErrors.contact = "Contact must be exactly 10 digits";
    if (!formData.bhk) tempErrors.bhk = "Please select a BHK option";
    if (!formData.type) tempErrors.type = "Please select a property type";
    setErrors(tempErrors);
    return Object.keys(tempErrors).length === 0;
  };

  const handleChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({ ...prev, [name]: value }));
  };

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (!validate()) return;

    setLoading(true);
    setToast(null);

    try {
      // INSTRUCTION: Connect to your real backend endpoint here.
      // The backend will handle saving the booking and triggering the WhatsApp message.
      const response = await fetch('/api/bookings', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(formData)
      });

      if (!response.ok) throw new Error("Network response was not ok");

      // Simulating API delay for WhatsApp trigger
      await new Promise(resolve => setTimeout(resolve, 1500)); 

      setToast('success');
      setFormData({ name: '', contact: '', bhk: '', type: '' }); // Reset form
    } catch (error) {
      console.error("Booking error:", error);
      setToast('error');
    } finally {
      setLoading(false);
      setTimeout(() => setToast(null), 4000);
    }
  };

  return (
    <section id="booking" className="py-24 bg-slate-900 relative overflow-hidden">
      {/* Background pattern */}
      <div className="absolute inset-0 opacity-10" style={{ backgroundImage: 'radial-gradient(circle at 1px 1px, white 1px, transparent 0)', backgroundSize: '40px 40px' }}></div>

      <div className="container mx-auto px-6 max-w-2xl relative z-10">
        <motion.div 
          className="text-center mb-10"
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true }}
        >
          <h2 className="text-4xl font-serif text-white mb-2">Book Your Dream Villa</h2>
          <p className="text-slate-400">Schedule a visit or get a callback from our experts.</p>
        </motion.div>

        <motion.form 
          onSubmit={handleSubmit}
          className="bg-slate-800/80 backdrop-blur-sm border border-slate-700 rounded-2xl p-8 shadow-2xl space-y-6"
          initial={{ opacity: 0, y: 30 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true }}
        >
          <div>
            <label className="block text-sm font-medium text-slate-300 mb-2">Full Name</label>
            <input
              type="text"
              name="name"
              value={formData.name}
              onChange={handleChange}
              className={`w-full bg-slate-900/50 border ${errors.name ? 'border-red-500' : 'border-slate-600'} rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition`}
              placeholder="John Doe"
            />
            {errors.name && <p className="text-red-400 text-xs mt-1">{errors.name}</p>}
          </div>

          <div>
            <label className="block text-sm font-medium text-slate-300 mb-2">Contact Number</label>
            <input
              type="tel"
              name="contact"
              value={formData.contact}
              onChange={handleChange}
              maxLength="10"
              className={`w-full bg-slate-900/50 border ${errors.contact ? 'border-red-500' : 'border-slate-600'} rounded-lg px-4 py-3 text-white focus:ring-2 focus:ring-amber-500 focus:border-transparent outline-none transition`}
              placeholder="9876543210"
            />
            {errors.contact && <p className="text-red-400 text-xs mt-1">{errors.contact}</p>}
          </div>

          <div>
            <label className="block text-sm font-medium text-slate-300 mb-2">BHK Option</label>
            <div className="grid grid-cols-2 gap-4">
              {['2 BHK', '3 BHK'].map(option => (
                <label key={option} className="cursor-pointer">
                  <input
                    type="radio"
                    name="bhk"
                    value={option}
                    checked={formData.bhk === option}
                    onChange={handleChange}
                    className="peer sr-only"
                  />
                  <div className="bg-slate-900/50 border border-slate-600 rounded-lg p-4 text-center text-slate-400 peer-checked:bg-amber-500/10 peer-checked:text-amber-400 peer-checked:border-amber-500 transition flex items-center justify-center gap-2">
                    <BedDouble className="w-5 h-5" /> {option}
                  </div>
                </label>
              ))}
            </div>
            {errors.bhk && <p className="text-red-400 text-xs mt-1">{errors.bhk}</p>}
          </div>

          <div>
            <label className="block text-sm font-medium text-slate-300 mb-2">Type</label>
            <div className="grid grid-cols-2 gap-4">
              {['Property', 'Land'].map(option => (
                <label key={option} className="cursor-pointer">
                  <input
                    type="radio"
                    name="type"
                    value={option}
                    checked={formData.type === option}
                    onChange={handleChange}
                    className="peer sr-only"
                  />
                  <div className="bg-slate-900/50 border border-slate-600 rounded-lg p-4 text-center text-slate-400 peer-checked:bg-amber-500/10 peer-checked:text-amber-400 peer-checked:border-amber-500 transition flex items-center justify-center gap-2">
                    {option === 'Property' ? <Building className="w-5 h-5" /> : <Tree className="w-5 h-5" />} {option}
                  </div>
                </label>
              ))}
            </div>
            {errors.type && <p className="text-red-400 text-xs mt-1">{errors.type}</p>}
          </div>

          <button
            type="submit"
            disabled={loading}
            className="w-full bg-amber-500 hover:bg-amber-600 text-white font-bold py-4 rounded-lg transition-all duration-300 flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed shadow-lg shadow-amber-500/20"
          >
            {loading ? (
              <>
                <Loader2 className="w-5 h-5 animate-spin" /> Processing...
              </>
            ) : (
              'Submit Booking'
            )}
          </button>
        </motion.form>

        {/* Toast Notification */}
        <AnimatePresence>
          {toast && (
            <motion.div 
              className={`fixed bottom-8 right-8 px-6 py-4 rounded-lg shadow-2xl flex items-center gap-3 z-50 ${toast === 'success' ? 'bg-green-600' : 'bg-red-600'}`}
              initial={{ opacity: 0, y: 50, scale: 0.9 }}
              animate={{ opacity: 1, y: 0, scale: 1 }}
              exit={{ opacity: 0, y: 50, scale: 0.9 }}
            >
              {toast === 'success' ? <CheckCircle className="w-6 h-6 text-white" /> : <X className="w-6 h-6 text-white" />}
              <p className="text-white font-medium">
                {toast === 'success' ? "Thanks! We'll contact you shortly." : "Oops! Something went wrong."}
              </p>
            </motion.div>
          )}
        </AnimatePresence>
      </div>
    </section>
  );
}

