// Procedural Low-Poly Placeholder Villa (No external file needed to run this code)
function PlaceholderVilla() {
  const ref = useRef();
  useFrame(({ clock }) => {
    if (ref.current) {
      ref.current.rotation.y = clock.getElapsedTime() * 0.1; // Gentle auto-rotation
    }
  });

  return (
    <group ref={ref} dispose={null}>
      {/* Base / Garden */}
      <mesh position={[0, -1.5, 0]} receiveShadow>
        <boxGeometry args={[8, 0.5, 8]} />
        <meshStandardMaterial color="#2d5a27" />
      </mesh>
      {/* Main Building */}
      <mesh position={[0, 0, 0]} castShadow receiveShadow>
        <boxGeometry args={[4, 3, 4]} />
        <meshStandardMaterial color="#e0e0e0" />
      </mesh>
      {/* Roof */}
      <mesh position={[0, 2, 0]} castShadow>
        <coneGeometry args={[3.5, 1.5, 4]} />
        <meshStandardMaterial color="#8b3a3a" />
      </mesh>
      {/* Door */}
      <mesh position={[0, -0.5, 2.01]}>
        <boxGeometry args={[1, 1.5, 0.1]} />
        <meshStandardMaterial color="#4a2c2a" />
      </mesh>
      {/* Windows */}
      <mesh position={[-1.5, 0.5, 2.01]}>
        <boxGeometry args={[0.8, 0.8, 0.1]} />
        <meshStandardMaterial color="#87ceeb" metalness={0.5} roughness={0.1} />
      </mesh>
      <mesh position={[1.5, 0.5, 2.01]}>
        <boxGeometry args={[0.8, 0.8, 0.1]} />
        <meshStandardMaterial color="#87ceeb" metalness={0.5} roughness={0.1} />
      </mesh>
      {/* Trees */}
      <group position={[3, -1, 2]}>
        <mesh position={[0, 0.5, 0]} castShadow>
          <cylinderGeometry args={[0.1, 0.1, 1]} />
          <meshStandardMaterial color="#5a3a2a" />
        </mesh>
        <mesh position={[0, 1.2, 0]} castShadow>
          <sphereGeometry args={[0.6, 8, 8]} />
          <meshStandardMaterial color="#3a6a35" />
        </mesh>
      </group>
    </group>
  );
}

